# =============================================================================
# .env.example — Byabsayee ERP  (SAFE TO COMMIT — no real passwords here)
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file and rename it to .env
#   2. Fill in YOUR values below
#   3. NEVER commit .env to git — only .env.example
# =============================================================================

APP_NAME=Byabsayee
APP_ENV=production

# Generate APP_KEY with: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=CHANGE_ME_generate_a_64char_hex_string

APP_URL=http://YOUR_SERVER_IP:1021
SESSION_NAME=byabsayee_session

# --- Uploads ---
# Path where uploaded files are stored on the server/container.
# In Docker: must match the volume mount in docker-compose.yml
# Leave blank to use <project_root>/uploads (good for local dev)
UPLOAD_PATH=/Sites/byabsayee/uploads

# --- Database ---
DB_HOST=db
DB_PORT=3306
DB_NAME=byabsayee_db
DB_USER=byabsayee_user
DB_PASS=CHANGE_ME_strong_password_here

MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_root_password_here

# --- Email (SMTP) ---
# For Gmail: use an App Password (not your real password)
# Go to: myaccount.google.com > Security > 2-Step Verification > App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=CHANGE_ME_your_app_password
SMTP_FROM=your_email@gmail.com
SMTP_FROM_NAME=Byabsayee
SMTP_ENCRYPTION=tls

# Email that receives "Contact Us" messages from users
SUPPORT_EMAIL=your_email@gmail.com

# --- WhatsApp (optional — leave as-is if not using) ---
WHATSAPP_API_KEY=your_permanent_system_user_token
WHATSAPP_API_URL=https://graph.facebook.com
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
